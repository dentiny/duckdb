# name: test/sql/index/art/constraints/create_unique_index_concurrent_duplicate.test_slow
# description: duplicate inserted during concurrent CREATE UNIQUE INDEX must throw a clean constraint error (not corrupt, not silent)
# group: [constraints]

statement ok
SET checkpoint_threshold='100GB'

statement ok
CREATE TABLE t AS SELECT range::BIGINT AS i FROM range(1000000)

concurrentloop threadid 0 5

# thread 0 builds the unique index; it must FAIL because threads 1..4 insert colliding keys during the build
onlyif threadid=0
statement error
CREATE UNIQUE INDEX idx ON t (i)
----
<REGEX>:.*duplicate key value violates unique constraint.*

# threads 1..4 all insert the SAME set of brand-new keys -> cross-thread duplicates only resolvable at replay
loop x 0 2000

onlyif threadid<>0
statement ok
INSERT INTO t (i) VALUES (7000000000 + {x})

endloop

endloop
