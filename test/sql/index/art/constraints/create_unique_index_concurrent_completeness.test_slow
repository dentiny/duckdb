# name: test/sql/index/art/constraints/create_unique_index_concurrent_completeness.test_slow
# description: concurrent CREATE UNIQUE INDEX with only distinct inserts -> all rows visible, none lost
# group: [constraints]

statement ok
SET checkpoint_threshold='100GB'

statement ok
CREATE TABLE t AS SELECT range::BIGINT AS i FROM range(1000000)

concurrentloop threadid 0 5

onlyif threadid=0
statement ok
CREATE UNIQUE INDEX idx ON t (i)

loop x 0 2000

onlyif threadid<>0
statement ok
INSERT INTO t (i) VALUES (({threadid}::BIGINT * 1000000000) + {x})

endloop

endloop

# all original + inserted rows must be present (1000000 + 4 threads * 2000)
query I
SELECT COUNT(*) FROM t
----
1008000

# every inserted row must be findable (via index once built)
query I
SELECT COUNT(*) FROM t WHERE i = (1::BIGINT * 1000000000 + 5)
----
1

query I
SELECT COUNT(*) FROM t WHERE i = (4::BIGINT * 1000000000 + 1999)
----
1

# no duplicates exist
query I
SELECT COUNT(*) FROM (SELECT i FROM t GROUP BY i HAVING COUNT(*) > 1)
----
0
