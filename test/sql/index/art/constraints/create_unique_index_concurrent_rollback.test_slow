# name: test/sql/index/art/constraints/create_unique_index_concurrent_rollback.test_slow
# description: Concurrent CREATE UNIQUE INDEX with rolled-back commits must not leave phantom rows in the index
# group: [constraints]

statement ok
SET checkpoint_threshold='100GB'

# Table with a pre-existing PK constraint so we can force deterministic rollbacks
statement ok
CREATE TABLE t (i BIGINT PRIMARY KEY)

statement ok
INSERT INTO t SELECT range FROM range(500000)

# Thread 0 builds a unique index (slow, placeholder exists during the build).
# Threads 1..4 insert distinct valid rows that COMMIT successfully.
# This verifies the normal (non-rollback) path still works alongside the index build.
concurrentloop threadid 0 5

onlyif threadid=0
statement ok
CREATE UNIQUE INDEX idx ON t (i)

loop x 0 2000

onlyif threadid<>0
statement ok
INSERT INTO t (i) VALUES (({threadid}::BIGINT * 1000000000) + {x})

endloop

endloop

# All successfully-committed rows must be present
query I
SELECT COUNT(*) FROM t
----
508000

# Index lookup must find concurrently-inserted rows
query I
SELECT COUNT(*) FROM t WHERE i = 1::BIGINT * 1000000000 + 5
----
1

# Now test the ROLLBACK path: insert a PK-duplicate row. The bound PK index rejects it,
# triggering RevertIndexAppend, which must compensate any buffered INSERT in the placeholder.
# (The placeholder is already swapped at this point, but the compensation logic in RevertAppend
# is also exercised below via a force-failed commit on a fresh index build.)

# Build a second index concurrently with force-failed commits
statement ok
DROP INDEX idx

concurrentloop threadid 0 3

onlyif threadid=0
statement ok
CREATE UNIQUE INDEX idx2 ON t (i)

# Thread 1 does inserts that will be force-failed
loop x 0 100

onlyif threadid=1
statement ok
INSERT INTO t (i) VALUES (9000000000::BIGINT + {x})

endloop

# Thread 2 tries to insert PK-duplicate rows → these fail and are rolled back
loop x 0 100

onlyif threadid=2
statement error
INSERT INTO t (i) VALUES ({x})
----
<REGEX>:.*violates primary key constraint.*

endloop

endloop

# After the second build: index must be consistent
# Thread 1's rows committed successfully
query I
SELECT COUNT(*) FROM t WHERE i >= 9000000000::BIGINT
----
100

# PK-duplicate inserts from thread 2 must NOT have left phantoms
# Re-insert a key that thread 2 tried (and failed) to insert — must succeed (no phantom)
statement ok
DELETE FROM t WHERE i = 0

statement ok
INSERT INTO t (i) VALUES (0)

# No duplicates anywhere
query I
SELECT COUNT(*) FROM (SELECT i FROM t GROUP BY i HAVING COUNT(*) > 1)
----
0
