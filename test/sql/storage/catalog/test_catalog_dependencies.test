# name: test/sql/storage/catalog/test_catalog_dependencies.test
# description: Persist catalog dependencies used for DROP and recreation ordering
# group: [catalog]

require skip_reload

load {TEST_DIR}/catalog_dependencies.db

statement ok
CREATE SEQUENCE z_sequence;

statement ok
CREATE MACRO a_macro() AS nextval('z_sequence');

statement ok
CREATE TABLE dependency_base(i INTEGER DEFAULT a_macro());

statement ok
CREATE VIEW z_view AS SELECT * FROM dependency_base;

statement ok
CREATE VIEW a_view AS SELECT * FROM z_view;

statement ok
CHECKPOINT;

restart

query TTT rowsort
WITH entries AS (
    SELECT sequence_oid oid, sequence_name name FROM duckdb_sequences()
    UNION ALL
    SELECT function_oid, function_name FROM duckdb_functions() WHERE NOT internal
    UNION ALL
    SELECT table_oid, table_name FROM duckdb_tables() WHERE NOT internal
    UNION ALL
    SELECT view_oid, view_name FROM duckdb_views() WHERE NOT internal
)
SELECT dependent.name, subject.name, dependency.deptype
FROM duckdb_dependencies() dependency
JOIN entries subject ON subject.oid = dependency.objid
JOIN entries dependent ON dependent.oid = dependency.refobjid
----
a_macro	z_sequence	n
a_view	dependency_base	n
a_view	z_view	n
dependency_base	a_macro	n
dependency_base	z_sequence	n
z_view	dependency_base	n

# View dependencies prevent the referenced table from being altered.
statement error
ALTER TABLE dependency_base RENAME TO renamed_dependency_base;
----
Dependency Error: Cannot alter entry "dependency_base" because there are entries that depend on it.

statement ok
DROP TABLE dependency_base CASCADE;

query I
SELECT COUNT(*) FROM duckdb_views() WHERE NOT internal;
----
0
