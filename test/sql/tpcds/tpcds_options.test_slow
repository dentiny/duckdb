# name: test/sql/tpcds/tpcds_options.test_slow
# description: Test TPC-DS data generation options
# group: [tpcds]

require tpcds

statement ok
CALL dsdgen(sf=0::DOUBLE)

# tables already exist
statement error
CALL dsdgen(sf=0::DOUBLE)
----

# overwrite should work
statement ok
CALL dsdgen(sf=0::DOUBLE, overwrite=true)

# suffix
statement ok
CALL dsdgen(sf=0.01::DOUBLE, suffix='_bla')

statement ok
SELECT COUNT(*) FROM call_center_bla

statement ok
create schema tpcds

statement ok
CALL dsdgen(sf=0.01::DOUBLE, schema='tpcds')

statement ok
SELECT COUNT(*) FROM tpcds.call_center

statement ok
ATTACH DATABASE ':memory:' AS db1;

statement ok
CALL dsdgen(sf=0.01::DOUBLE, catalog='db1');

statement ok
SELECT COUNT(*) FROM db1.call_center

statement ok
CREATE SCHEMA db1.test_schema

statement ok
CALL dsdgen(sf=0.01::DOUBLE, catalog='db1', schema='test_schema');

statement ok
SELECT COUNT(*) FROM db1.test_schema.call_center

statement error
Call dsdgen(sf=NULL);
----
<REGEX>:Invalid Input Error:.*dsdgen.*NULL.*sf

statement error
Call dsdgen(catalog=NULL);
----
<REGEX>:Invalid Input Error:.*dsdgen.*NULL.*catalog

statement error
Call dsdgen(sf=1::DOUBLE, suffix=NULL);
----
<REGEX>:Invalid Input Error:.*dsdgen.*NULL.*suffix
